<resources>
    <style name="ProfileCard">
        <item name="android:background">@color/grey_light</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <style name="ProfileImage">
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <style name="ProfileName">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="ProfileEmail">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/blue_dark</item>
    </style>

    <style name="ProfileVerified">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/green_light</item>
    </style>

    <style name="ProfileStatsLayout">
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <style name="ProfileStatsText">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ProfileNavText">
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:background">@color/grey_light</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="BottomNavLayout">
        <item name="android:background">@color/grey_light</item>
    </style>

    <style name="BottomNavItem">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="BottomNavItemActive">
        <item name="android:gravity">center</item>
    </style>
</resources>