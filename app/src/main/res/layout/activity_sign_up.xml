<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:id="@+id/layout_register_main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    style="@style/MainLayout"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <LinearLayout
            android:id="@+id/layout_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            style="@style/LoginLayout"
            >

            <ImageView
                android:id="@+id/iv_register_logo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/img"
                style="@style/LogoImage"
                />

            <TextView
                android:id="@+id/tv_register_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chào mừng đến EduShare"
                style="@style/TitleText"
                />

            <TextView
                android:id="@+id/tv_register_sub_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sàn giao dịch tài nguyên học thuật dành cho sinh viên"
                style="@style/SubTitleText"
                />

            <LinearLayout
                android:id="@+id/layout_register_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                style="@style/LoginFormLayout"
                >

                <LinearLayout
                    android:id="@+id/layout_register_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:orientation="horizontal"
                    style="@style/ToggleLayout">

                    <TextView
                        android:id="@+id/tv_register_login"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Đăng nhập"
                        style="@style/SignUpBox"
                        />

                    <TextView
                        android:id="@+id/tv_register_sign_up"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Đăng ký"
                        style="@style/LoginBox"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_fullname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên"
                    style="@style/EmailTextView"
                    />

                <EditText
                    android:id="@+id/te_fullname"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập họ và tên"
                    style="@style/EmailTextEdit"
                    />

                <TextView
                    android:id="@+id/tv_register_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email sinh viên"
                    style="@style/EmailTextView"
                    />

                <EditText
                    android:id="@+id/te_register_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="student@university.edu"
                    style="@style/EmailTextEdit"
                    />

                <TextView
                    android:id="@+id/tv_register_note"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sử dụng email sinh viên chính thức!"
                    style="@style/Note"/>

                <TextView
                    android:id="@+id/tv_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại"
                    style="@style/EmailTextView"
                    />

                <EditText
                    android:id="@+id/te_phone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập số điện thoại"
                    style="@style/EmailTextEdit"
                    />

                <TextView
                    android:id="@+id/tv_register_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    style="@style/EmailTextView"
                    />

                <EditText
                    android:id="@+id/te_register_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập mật khẩu"
                    android:inputType="textPassword"
                    style="@style/EmailTextEdit"
                    />

                <TextView
                    android:id="@+id/tv_register_password_rewrite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập lại mật khẩu"
                    style="@style/EmailTextView"
                    />

                <EditText
                    android:id="@+id/te_register_password_rewrite"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập lại mật khẩu"
                    android:inputType="textPassword"
                    style="@style/EmailTextEdit"
                    />

                <Button
                    android:id="@+id/btn_create_account"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Tạo tài khoản"
                    style="@style/LoginButton"
                    />

                <TextView
                    android:id="@+id/tv_sub_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bạn đã có tài khoản? Đăng nhập"
                    style="@style/SubSignUp"
                    />

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn đồng ý với Điều khoản dịch vụ và Chính sách bảo mật"
            style="@style/MadeBy"
            />

    </LinearLayout>
</ScrollView>
